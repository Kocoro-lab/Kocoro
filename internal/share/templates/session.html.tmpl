<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="robots" content="noindex, nofollow">
<title>{{.Title}} · Kocoro</title>
{{/* ========== SEO ========== */}}
{{- if .Description}}
<meta name="description" content="{{.Description}}">
{{- end}}
<meta name="author" content="{{.SiteName}}">

{{/* ========== Open Graph (Slack / Teams / WeChat / Facebook / LinkedIn) ========== */}}
<meta property="og:type" content="article">
<meta property="og:title" content="{{.OGTitle}}">
{{- if .Description}}
<meta property="og:description" content="{{.Description}}">
{{- end}}
{{- if .OGImage}}
<meta property="og:image" content="{{.OGImage}}">
<meta property="og:image:alt" content="{{.OGTitle}}">
{{- end}}
<meta property="og:site_name" content="{{.SiteName}}">
<meta property="og:locale" content="en_US">
{{- if .CreatedAtISO}}
<meta property="article:published_time" content="{{.CreatedAtISO}}">
{{- end}}
{{- if .GeneratedAtISO}}
<meta property="article:modified_time" content="{{.GeneratedAtISO}}">
{{- end}}

{{/* ========== Twitter / X Card ========== */}}
<meta name="twitter:card" content="{{if .TwitterImage}}summary_large_image{{else}}summary{{end}}">
<meta name="twitter:title" content="{{.OGTitle}}">
{{- if .Description}}
<meta name="twitter:description" content="{{.Description}}">
{{- end}}
{{- if .TwitterImage}}
<meta name="twitter:image" content="{{.TwitterImage}}">
<meta name="twitter:image:alt" content="{{.OGTitle}}">
{{- end}}

{{/* ========== Favicon (sourced from kocoro.ai so the share file stays self-contained) ========== */}}
{{- if .SiteURL}}
<link rel="icon" type="image/x-icon" href="{{.SiteURL}}favicon.ico">
{{- end}}

{{/* ========== Structured data — schema.org Article, publisher = Kocoro ========== */}}
<script type="application/ld+json">{{.JSONLD}}</script>
<style>
  :root {
    color-scheme: light dark;
    /* Warm cream palette inspired by Claude.ai — feels approachable, not clinical.
       Avoid sterile pure-white backgrounds; cream reads better for long-form text. */
    --bg: #F8F5EE;
    --surface: #FFFCF5;
    --surface-2: #F2EDE2;
    --fg: #1B1A17;
    --fg-soft: #4A463F;
    --muted: #8A857C;
    --border: #E5DFD0;
    --border-soft: #EFEADE;
    --accent: #C96442;
    --accent-soft: #E89274;
    --code-bg: #F0EBE0;
    --code-fg: #1B1A17;
    --shadow-soft: 0 1px 2px rgba(40, 30, 20, 0.04);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1B1A17;
      --surface: #232220;
      --surface-2: #1F1E1B;
      --fg: #E8E2D5;
      --fg-soft: #BFB8A9;
      --muted: #7A746B;
      --border: #2F2D29;
      --border-soft: #29272300;
      --accent: #D67855;
      --accent-soft: #F09375;
      --code-bg: #14130F;
      --code-fg: #E8E2D5;
      --shadow-soft: 0 1px 2px rgba(0, 0, 0, 0.4);
    }
  }
  * { box-sizing: border-box; }
  html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI",
      "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue", sans-serif;
    font-size: 16px;
    line-height: 1.65;
  }
  main {
    max-width: 740px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }
  @media (max-width: 600px) {
    main { padding: 32px 16px 64px; }
    body { font-size: 15px; }
  }

  /* ===== Header ===== */
  header.share-header {
    margin-bottom: 40px;
  }
  header.share-header h1 {
    margin: 0 0 10px;
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.25;
    color: var(--fg);
  }
  header.share-header .meta {
    color: var(--muted);
    font-size: 13.5px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  header.share-header .meta .dot { color: var(--border); }
  header.share-header .meta code {
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 12.5px;
    color: var(--fg-soft);
  }

  /* ===== Summary card ===== */
  .summary {
    margin-top: 28px;
    padding: 24px 26px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    box-shadow: var(--shadow-soft);
  }
  .summary .label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .summary .label::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .summary .body { color: var(--fg-soft); }
  .summary .body > *:first-child { margin-top: 0; }
  .summary .body > *:last-child { margin-bottom: 0; }

  /* ===== Conversation ===== */
  .conversation { margin-top: 16px; }

  /* Centered uppercase label flanked by thin lines — separates the summary
     card from the actual transcript so the reader knows the synopsis ends
     here and live conversation starts. Style matches the summary label
     family (uppercase, letter-spaced, muted) without competing with it. */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 40px 0 20px;
  }
  .section-divider::before,
  .section-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .section-divider span {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    white-space: nowrap;
  }

  article.msg {
    margin: 28px 0;
    word-wrap: break-word;
  }
  article.msg:first-child { margin-top: 8px; }

  /* User: subtle right-leaning bubble — keeps the visual asymmetry of a
     conversation while staying flat (no shadows). */
  article.msg.user {
    display: flex;
    justify-content: flex-end;
  }
  article.msg.user .bubble {
    max-width: 88%;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: 18px 18px 4px 18px;
    color: var(--fg);
  }
  article.msg.user .role { display: none; } /* implicit from bubble alignment */

  /* Assistant + tool: full-width, no bubble — the page itself is the surface.
     A subtle accent dot on the left provides the only visual marker. Tool
     messages (Anthropic-API user role carrying only tool_result blocks) use
     a muted color to mark them as agent-loop flow rather than typed input. */
  article.msg.assistant,
  article.msg.tool {
    position: relative;
    padding-left: 18px;
  }
  article.msg.assistant::before,
  article.msg.tool::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  article.msg.assistant::before { background: var(--accent); }
  article.msg.tool::before      { background: var(--muted); }

  .role {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 6px;
    letter-spacing: 0.02em;
  }
  .role time {
    font-weight: 400;
    margin-left: 8px;
    font-variant-numeric: tabular-nums;
  }

  /* ===== Rendered markdown content ===== */
  .content {
    /* overflow-wrap: anywhere — break long unwordable tokens (URLs, hashes)
       only when needed; natural word/CJK boundaries still wrap normally. */
    overflow-wrap: anywhere;
    word-wrap: break-word;
  }
  .content > *:first-child { margin-top: 0; }
  .content > *:last-child { margin-bottom: 0; }
  .content p { margin: 0 0 14px; }
  .content h1, .content h2, .content h3, .content h4 {
    margin: 22px 0 10px;
    line-height: 1.3;
    color: var(--fg);
    font-weight: 600;
  }
  .content h1 { font-size: 20px; }
  .content h2 { font-size: 17px; }
  .content h3 { font-size: 15.5px; }
  .content h4 { font-size: 14.5px; color: var(--fg-soft); }
  .content ul, .content ol { margin: 0 0 14px; padding-left: 24px; }
  .content li { margin: 4px 0; }
  .content li > p { margin: 0 0 6px; }
  .content a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .content a:hover { border-bottom-color: var(--accent); }
  .content blockquote {
    margin: 14px 0;
    padding: 2px 14px;
    border-left: 3px solid var(--border);
    color: var(--fg-soft);
  }
  .content hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 28px 0;
  }
  .content code {
    background: var(--code-bg);
    padding: 1.5px 5px;
    border-radius: 4px;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 0.88em;
    color: var(--code-fg);
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .content pre {
    background: var(--code-bg);
    border-radius: 8px;
    padding: 14px 16px;
    margin: 14px 0;
    overflow-x: auto;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 13px;
    line-height: 1.55;
    color: var(--code-fg);
  }
  .content pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
  .content table {
    border-collapse: collapse;
    margin: 14px 0;
    font-size: 14px;
    width: 100%;
  }
  .content table th,
  .content table td {
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  .content table th {
    color: var(--muted);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .content img {
    max-width: 100%;
    height: auto;
    margin: 10px 0;
    border-radius: 8px;
    border: 1px solid var(--border-soft);
  }

  /* Standalone images (image content blocks attached to messages) */
  .msg-image {
    margin: 10px 0;
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border-soft);
    display: block;
  }

  /* html-artifact widgets, rendered live in a sandboxed iframe. The iframe's
     own design system lives inside its srcdoc (mirrored from Desktop); these
     rules only frame it on the share page. Height is set by the autosize
     listener from the iframe's posted scrollHeight. */
  figure.artifact {
    margin: 12px 0;
  }
  figure.artifact .artifact-title {
    font-size: 12.5px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  iframe.kocoro-artifact {
    width: 100%;
    min-height: 120px;
    border: 0;
    display: block;
    background: transparent;
  }

  /* ===== Footer ===== */
  footer.share-footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 12.5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  footer.share-footer a {
    /* Kocoro brand color — hardcoded so it stays consistent across light/dark
       themes and doesn't drift if --accent is re-tuned for other UI accents. */
    color: #FE2F5C;
    text-decoration: none;
    font-weight: 500;
  }
  footer.share-footer a:hover { text-decoration: underline; }
  footer.share-footer code {
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 11.5px;
    color: var(--fg-soft);
  }
</style>
</head>
<body>
<main>
<header class="share-header">
  <h1>{{.Title}}</h1>
  <div class="meta">
    {{if .AgentName}}<span><code>{{.AgentName}}</code></span><span class="dot">·</span>{{end}}
    <span>{{.MessageCount}} message{{if ne .MessageCount 1}}s{{end}}</span>
    {{if .CreatedAt}}<span class="dot">·</span><time datetime="{{.CreatedAtISO}}">{{.CreatedAt}}</time>{{end}}
  </div>
  {{if .SummaryHTML}}
  <section class="summary">
    <div class="label">Summary</div>
    <div class="body content">{{.SummaryHTML}}</div>
  </section>
  {{end}}
</header>

<section class="conversation">
  {{if .SummaryHTML}}
  <div class="section-divider"><span>Conversation</span></div>
  {{end}}
{{range .Messages}}
<article class="msg {{.Role}}">
  {{if and (eq .Role "user") .BubbleBlocks}}
    <div class="bubble">
      {{range .BubbleBlocks}}
        {{if eq .Kind "text"}}<div class="content">{{.HTML}}</div>{{end}}
        {{if eq .Kind "image"}}<img class="msg-image" src="{{.ImageDataURI}}" alt="attached image" loading="lazy">{{end}}
        {{if eq .Kind "artifact"}}{{template "artifact" .}}{{end}}
      {{end}}
    </div>
  {{else if .BubbleBlocks}}
    <div class="role">
      {{.RoleLabel}}{{if .Timestamp}}<time datetime="{{.TimestampISO}}" data-fmt="time">{{.Timestamp}}</time>{{end}}
    </div>
    {{range .BubbleBlocks}}
      {{if eq .Kind "text"}}<div class="content">{{.HTML}}</div>{{end}}
      {{if eq .Kind "image"}}<img class="msg-image" src="{{.ImageDataURI}}" alt="attached image" loading="lazy">{{end}}
      {{if eq .Kind "artifact"}}{{template "artifact" .}}{{end}}
    {{end}}
  {{end}}
  {{if .AsideBlocks}}
    {{if not .BubbleBlocks}}
      <div class="role">
        {{.RoleLabel}}{{if .Timestamp}}<time datetime="{{.TimestampISO}}" data-fmt="time">{{.Timestamp}}</time>{{end}}
      </div>
    {{end}}
    {{range .AsideBlocks}}
      {{if eq .Kind "tool_image"}}
        {{range .NestedImages}}<img class="msg-image" src="{{.}}" alt="tool image" loading="lazy">{{end}}
      {{end}}
    {{end}}
  {{end}}
</article>
{{end}}
</section>

<footer class="share-footer">
  <span>Shared from <a href="https://kocoro.ai">Kocoro</a></span>
  {{if .GeneratedAt}}<time datetime="{{.GeneratedAtISO}}">{{.GeneratedAt}}</time>{{end}}
</footer>
</main>

{{/*
  localize-timestamps: rewrite every <time datetime="..."> element in the
  document to the viewer's local timezone + locale. Server-side rendering
  emits UTC as a static fallback (works for no-JS / no-Intl viewers); this
  script upgrades it in-place so a Tokyo viewer reads JST and a London
  viewer reads BST off the same uploaded HTML.

  Why two formats (date+time vs message-bubble timestamp): the header and
  footer carry full date+time stamps; message-bubble timestamps (rendered
  by viewMessage.TimestampISO) are time-of-day only. We discriminate by
  presence of the "data-fmt='time'" attribute that buildViewMessages tags
  message timestamps with.

  Fail-quiet: any error (invalid ISO, missing Intl API on a very old
  browser) leaves the server-rendered UTC text alone — never throws.
*/}}
<script id="localize-timestamps">
(function() {
  if (typeof Intl === 'undefined' || !Intl.DateTimeFormat) return;
  var locale = (navigator.language || 'en-US');
  var dateTimeFmt = new Intl.DateTimeFormat(locale, {
    year: 'numeric', month: 'short', day: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZoneName: 'short'
  });
  var timeOnlyFmt = new Intl.DateTimeFormat(locale, {
    hour: '2-digit', minute: '2-digit'
  });
  var nodes = document.querySelectorAll('time[datetime]');
  for (var i = 0; i < nodes.length; i++) {
    var el = nodes[i];
    var iso = el.getAttribute('datetime');
    if (!iso) continue;
    var d = new Date(iso);
    if (isNaN(d.getTime())) continue;
    try {
      var formatter = (el.getAttribute('data-fmt') === 'time') ? timeOnlyFmt : dateTimeFmt;
      el.textContent = formatter.format(d);
    } catch (err) {
      // Leave the server-rendered UTC text in place.
    }
  }
})();
</script>

{{/*
  artifact-autosize: html-artifact iframes are sandboxed WITHOUT allow-same-origin,
  so they live in a null origin and we cannot read their content height directly.
  The wrapper document's bridge (buildArtifactSrcdoc) posts a kocoro-artifact-resize
  message with its scrollHeight; we match the sender to its iframe by
  data-artifact-id and set the height. This mirrors the receiver in Desktop's
  message-list.js. kocoro-artifact-error / -csp messages are ignored here.
*/}}
<script id="artifact-autosize">
(function() {
  window.addEventListener('message', function(e) {
    var d = e.data;
    if (!d || d.type !== 'kocoro-artifact-resize' || typeof d.id !== 'string') return;
    var sel = 'iframe.kocoro-artifact[data-artifact-id="' + (window.CSS && CSS.escape ? CSS.escape(d.id) : d.id) + '"]';
    var f = document.querySelector(sel);
    if (f && typeof d.height === 'number') f.style.height = Math.max(Math.ceil(d.height), 80) + 'px';
  });
})();
</script>
</body>
</html>

{{define "artifact"}}
<figure class="artifact">
  {{if .ArtifactTitle}}<figcaption class="artifact-title">{{.ArtifactTitle}}</figcaption>{{end}}
  <iframe class="kocoro-artifact" loading="lazy"
          sandbox="allow-scripts"
          data-artifact-id="{{.ArtifactID}}"
          title="{{.ArtifactTitle}}"
          srcdoc="{{.ArtifactSrcdoc}}"></iframe>
</figure>
{{end}}
